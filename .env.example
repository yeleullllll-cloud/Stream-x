# Stream X Environment Variables

# OMDB API Key (for movie data)
# Get your free key at: https://www.omdbapi.com/apikey.aspx
# Default key is provided, but you can add your own for higher quota
VITE_OMDB_API_KEY=7bed534b

# YouTube Data API v3 Key (for movie trailers)
# Get your free key at: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable "YouTube Data API v3"
# 3. Create credentials (API Key)
# 4. Copy the API key here
# 
# Note: Without this key, the app will use smart fallback trailers
# that match popular movies automatically (100+ movies supported)
YOUTUBE_API_KEY=

# Gemini API Key (optional - for search predictions)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
