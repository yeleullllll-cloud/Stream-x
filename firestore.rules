rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 0: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Schema Validators
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is timestamp &&
             data.userId == request.auth.uid &&
             (data.keys().hasAny(['displayName']) == false || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.keys().hasAny(['photoURL']) == false || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (data.keys().hasAny(['updatedAt']) == false || data.updatedAt is timestamp);
    }

    function isValidWatchlistItem(data) {
      return data.keys().hasAll(['movieId', 'title', 'poster', 'type', 'addedAt']) &&
             data.movieId is string && data.movieId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.poster is string && data.poster.size() <= 1000 &&
             data.type is string && data.type.size() <= 50 &&
             data.addedAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow list: if false; // No blanket listing of users

      allow create: if isSignedIn() && 
                    isValidId(userId) && 
                    userId == request.auth.uid &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().keys().size() <= 6; // Max keys based on schema

      allow update: if isSignedIn() &&
                    isValidId(userId) &&
                    userId == request.auth.uid &&
                    isValidUser(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
                    
      allow delete: if false; // Users shouldn't be deleted via client arbitrarily 
      
      match /watchlist/{movieId} {
        allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(movieId);
        allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);

        allow create: if isSignedIn() && 
                      isValidId(userId) && 
                      userId == request.auth.uid &&
                      isValidId(movieId) &&
                      isValidWatchlistItem(incoming()) &&
                      incoming().addedAt == request.time &&
                      incoming().keys().size() <= 5;

        allow update: if false; // Watchlist items are simply added or removed, not updated.
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(movieId);
      }
    }
  }
}
